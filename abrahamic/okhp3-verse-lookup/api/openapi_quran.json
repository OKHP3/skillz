{
  "openapi": "3.1.0",
  "info": {
    "title": "Quran.com Verses API",
    "version": "1.0.0",
    "description": "Fetch specific ayat (verses) from the Qur’an via Quran.com."
  },
  "servers": [
    { "url": "https://api.quran.com" }
  ],
  "paths": {
    "/api/v4/verses/by_key/{key}": {
      "get": {
        "operationId": "get_quran_ayah",
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Surah and ayah key formatted like '2:255'."
          },
          {
            "name": "language",
            "in": "query",
            "schema": { "type": "string", "default": "en" },
            "description": "Language code for the response (e.g., 'en')."
          },
          {
            "name": "translations",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Comma-separated list of translation IDs to include (e.g., '20,21')."
          }
        ],
        "responses": {
          "200": { "description": "Averse response including requested translations." }
        }
      }
    }
  }
}