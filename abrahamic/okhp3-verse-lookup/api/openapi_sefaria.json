{
  "openapi": "3.1.0",
  "info": {
    "title": "Sefaria Texts API",
    "version": "1.0.0",
    "description": "Retrieve Tanakh (and other Jewish text) passages from the Sefaria API."
  },
  "servers": [
    { "url": "https://www.sefaria.org" }
  ],
  "paths": {
    "/api/texts/{ref}": {
      "get": {
        "operationId": "get_sefaria_ref",
        "parameters": [
          {
            "name": "ref",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Reference formatted as Book.Chapter.Verse (e.g., Genesis.1.1)."
          },
          {
            "name": "lang",
            "in": "query",
            "schema": { "type": "string", "default": "en" },
            "description": "Language code ('en' for English, 'he' for Hebrew, 'he-en' for bilingual)."
          }
        ],
        "responses": {
          "200": { "description": "A text passage in JSON format." }
        }
      }
    }
  }
}