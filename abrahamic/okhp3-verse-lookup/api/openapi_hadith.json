{
  "openapi": "3.1.0",
  "info": {
    "title": "Hadith API (Stub)",
    "version": "0.1.0",
    "description": "Minimal stub for fetching hadith entries. Adjust the server URL and path according to the provider you choose."
  },
  "servers": [
    { "url": "https://YOUR-HADITH-PROVIDER" }
  ],
  "paths": {
    "/hadith/{collection}/{number}": {
      "get": {
        "operationId": "get_hadith",
        "parameters": [
          {
            "name": "collection",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Hadith collection name (e.g., 'bukhari', 'muslim')."
          },
          {
            "name": "number",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Hadith number within the collection."
          },
          {
            "name": "lang",
            "in": "query",
            "schema": { "type": "string", "default": "en" },
            "description": "Language code for the response."
          }
        ],
        "responses": {
          "200": { "description": "Hadith entry in JSON format." }
        }
      }
    }
  }
}