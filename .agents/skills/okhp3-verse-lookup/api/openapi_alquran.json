{
  "openapi": "3.1.0",
  "info": {
    "title": "AlQuran.cloud API",
    "version": "1.0.0",
    "description": "Fallback API for Qur’an verses when Quran.com is unavailable."
  },
  "servers": [
    { "url": "https://api.alquran.cloud" }
  ],
  "paths": {
    "/v1/ayah/{ayah}/{edition}": {
      "get": {
        "operationId": "get_quran_ayah_fallback",
        "parameters": [
          {
            "name": "ayah",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Ayah formatted like '2:255'."
          },
          {
            "name": "edition",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Edition code (e.g., 'en.asad' for Muhammad Asad translation)."
          }
        ],
        "responses": {
          "200": { "description": "Ayah in the specified edition." }
        }
      }
    }
  }
}